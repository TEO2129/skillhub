# Dependances - regenerees par composer dans le Dockerfile
vendor/
node_modules/

# Fichiers d'environnement - ne jamais inclure dans l'image
.env
.env.*
!.env.example

# Git
.git/
.gitignore
.gitattributes

# Documentation
README.md
CONTRIBUTING.md
*.md

# Tests - pas besoin en production
tests/
phpunit.xml
phpunit.xml.dist

# CI/CD
.github/

# Logs Laravel
storage/logs/*.log

# Cache Laravel
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# IDE
.vscode/
.idea/
*.swp

# SonarQube
sonar-project.properties
build/
